# Path to the auth state JSON produced by auth.py. Treat like a password.
STRAVA_AUTH_FILE=./auth.json

# Stop once this many already-kudo'd activities are on the page (i.e. you've
# gone "deep enough" into the feed). Bot exits early when this is reached.
STRAVA_KUDOED_LIMIT=100

# Hard safety cap on scroll iterations. Bot also stops if the feed has no more
# content to load, regardless of this value.
STRAVA_MAX_SCROLLS=30

# Milliseconds to wait after each scroll for new feed items to lazy-load.
STRAVA_SCROLL_DELAY_MS=2500

# Number of consecutive scrolls with no new content before declaring the
# feed exhausted. Higher tolerates slower Strava responses.
STRAVA_SCROLL_PATIENCE=3

# Milliseconds between each kudos click.
STRAVA_KUDOS_DELAY_MS=500

# Set to "false" to watch the bot run with a visible browser (useful for debugging).
STRAVA_HEADLESS=true

# Override only if Strava renames their kudos buttons.
# STRAVA_FEED_KUDOED_SELECTOR=button[data-testid='kudos_button']
# STRAVA_DETAIL_KUDOS_SELECTOR=button[data-testid='give-kudos-btn']
